# Kopiere diese Datei nach .env und trage echte Werte ein (.env bleibt lokal / nicht im Git).

# ——— SMTP / Versand ———
# MAIL_ENABLED=true (oder SMTP_ENABLED=true) schaltet den Versand über diesen Server ein.
MAIL_ENABLED=false

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Immobiliencheck <berichte@example.com>

# ——— HTTP-Server (Webapp + /api/send-report) ———
MAIL_SERVER_HOST=127.0.0.1
MAIL_SERVER_PORT=3847
MAIL_SERVE_STATIC=true
MAIL_SITE_ROOT=..

# Leerlassen = CORS für alle Origins (wie bisher ohne Liste). Sonst kommagetrennt, z. B.:
# MAIL_CORS_ORIGINS=http://127.0.0.1:3847,https://checkliste.example.com
MAIL_CORS_ORIGINS=

# Optional: gleicher Wert wird als Header X-Mail-Api-Token beim POST erwartet
MAIL_API_TOKEN=
